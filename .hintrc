{
  "extends": [
    "development"
  ],
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 26.4",
    "not safari <= 26.4",
    "not and_chr <= 146",
    "not chrome <= 146",
    "not edge <= 146",
    "not firefox <= 149",
    "not samsung <= 29",
    "not and_ff <= 149"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "-webkit-text-size-adjust",
          "-webkit-overflow-scrolling"
        ]
      }
    ],
    "meta-charset-utf-8": "off",
    "axe/time-and-media": [
      "default",
      {
        "meta-refresh": "off"
      }
    ]
  }
}